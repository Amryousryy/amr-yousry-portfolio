# MongoDB
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/portfolio

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-generated-secret

# Admin credentials
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your-password

# Cloudinary (public — safe for browser)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=dpax6u61z
# Option A — existing preset with spaces (must match Cloudinary exactly):
# NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=Amr Yousry
# Option B — recommended: create a preset without spaces:
# NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=portfolio_unsigned

# Cloudinary (server-only — never expose to frontend)
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# The upload preset must be created in Cloudinary Dashboard
# with Signing Mode: Unsigned.
# Allowed formats: jpg, jpeg, png, webp, gif, mp4
